{
  "name": "eslint-plugin-require-explicit-array-types",
  "version": "1.0.0",
  "description": "ESLint plugin requiring explicit type annotations for empty arrays",
  "keywords": [
    "eslint",
    "eslintplugin",
    "eslint-plugin",
    "typescript",
    "array",
    "type-annotation",
    "explicit-types"
  ],
  "author": "Adam Sajko",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/adam-sajko/eslint-plugin-require-explicit-array-types"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "eslint": ">=8.0.0",

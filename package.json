    "@typescript-eslint/utils": "^8.0.0",
    "eslint": "^9.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "@typescript-eslint/utils": "^8.0.0"
  }
